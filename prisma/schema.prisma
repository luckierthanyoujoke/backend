// https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(cuid())
  clerkId               String               @unique
  email                 String               @unique
  name                  String
  avatarUrl             String?
  isPremium             Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  recipes               Recipe[]
  recipeLikes           RecipeLike[]
  favorites             Favorite[]
  conversationsAsFirst  DirectConversation[] @relation("ConversationFirstUser")
  conversationsAsSecond DirectConversation[] @relation("ConversationSecondUser")
  sentMessages          DirectMessage[]      @relation("DirectMessageSender")
  blockedUsers          BlockedUser[]        @relation("BlockedUserBlocker")
  blockedByUsers        BlockedUser[]        @relation("BlockedUserTarget")
  recipeComments        RecipeComment[]
  recipeRatings         RecipeRating[]
}

model Recipe {
  id           String   @id @default(cuid())
  title        String
  ingredients  String[]
  steps        String[]
  /** Broad grouping for filters (e.g. Italian, Breakfast). */
  category     String?
  /** Lowercase slug-style labels (e.g. pasta, quick). */
  tags         String[] @default([])
  /** Optional diet style (e.g. vegan, vegetarian, keto) — normalized lowercase. */
  diet         String?
  /** Dietary labels (e.g. gluten-free, nut-free) — normalized lowercase. */
  restrictions String[] @default([])
  /** AI-generated dish photo (URL), optional. */
  imageUrl     String?
  isAI         Boolean  @default(false)
  isPublished  Boolean  @default(false)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  recipeLikes  RecipeLike[]
  favorites    Favorite[]
  comments     RecipeComment[]
  ratings      RecipeRating[]
  sharedInMessages DirectMessage[]

  @@index([userId])
  @@index([isPublished, createdAt])
  @@index([category])
  @@index([diet])
}

model RecipeLike {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
  @@index([recipeId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
  @@index([recipeId])
  @@index([userId])
}

model RecipeComment {
  id        String   @id @default(cuid())
  body      String
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, createdAt])
  @@index([userId])
}

/** User score for a recipe (1–5). One row per user per recipe. */
model RecipeRating {
  id        String   @id @default(cuid())
  score     Int
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
  @@index([userId])
}

model DirectConversation {
  id           String        @id @default(cuid())
  firstUserId  String
  secondUserId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lastMessageAt DateTime     @default(now())
  firstUser    User          @relation("ConversationFirstUser", fields: [firstUserId], references: [id], onDelete: Cascade)
  secondUser   User          @relation("ConversationSecondUser", fields: [secondUserId], references: [id], onDelete: Cascade)
  messages     DirectMessage[]

  @@unique([firstUserId, secondUserId])
  @@index([firstUserId])
  @@index([secondUserId])
  @@index([lastMessageAt])
}

model DirectMessage {
  id             String             @id @default(cuid())
  conversationId String
  senderId       String
  text           String?
  recipeId       String?
  createdAt      DateTime           @default(now())
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipe         Recipe?            @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([recipeId])
}

model BlockedUser {
  id            String   @id @default(cuid())
  blockerUserId String
  blockedUserId String
  createdAt     DateTime @default(now())
  blocker       User     @relation("BlockedUserBlocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked       User     @relation("BlockedUserTarget", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockerUserId])
  @@index([blockedUserId])
}

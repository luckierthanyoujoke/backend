# backend/.env
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME
CLERK_SECRET_KEY=
FRONTEND_URL=http://localhost:5173
# Webhook signing secret (Clerk → Webhooks → your endpoint) — creates DB users on user.created
CLERK_WEBHOOK_SIGNING_SECRET=
# Stripe (Checkout + webhook — Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time premium price in cents (default 999 = $9.99)
STRIPE_PREMIUM_AMOUNT_CENTS=999
# Public URL of this API (optional; used for redirects / links)
API_PUBLIC_URL=http://localhost:3000
#
# AWS S3 — required for avatars and recipe images (no local ./uploads fallback)
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
# Standard names:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Or aliases (same as many AWS panels):
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=
#
# Public base URL for objects (must match how the bucket is accessed in the browser).
# If unset, defaults to https://BUCKET.s3.REGION.amazonaws.com
# Custom / website endpoint example:
# AWS_PUBLIC_BASE_URL=https://my-bucket.s3.us-east-1.amazonaws.com
# Or (legacy name in some projects):
# AWS_ENDPOINT=https://my-bucket.s3.us-east-1.amazonaws.com
#
# Only for S3-compatible APIs (MinIO, etc.), not the public URL above:
# AWS_S3_API_ENDPOINT=
#
# Optional: AI dish images (Pollinations — server-side, no API key)
# DISH_IMAGE_POLLINATIONS_MODEL=flux
# DISH_IMAGE_WIDTH=1024
# DISH_IMAGE_HEIGHT=1024
#
# LLM for recipe JSON (required for POST /recipes/ai-generate).
# Option A — OpenAI:
# OPENAI_API_KEY=sk-...
# Optional: OPENAI_MODEL=gpt-4o-mini
# Option B — OpenRouter (set all three; do not send OPENAI_API_KEY to OpenRouter):
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini
# If both OpenAI and OpenRouter vars exist, the API uses OpenRouter when KEY+BASE_URL are both set.
